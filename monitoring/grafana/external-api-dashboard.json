{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "외부 API(LastFM/Spotify/YouTube/Kakao/Apple/Discord) 호출 모니터링. external_api_* (RED) + 도메인 신호(캐시/coalesce/error29/quota).",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["external-api", "livith"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "label": "Tempo",
        "name": "TEMPO_DS",
        "query": "tempo",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "Asia/Seoul",
  "title": "External API Monitoring",
  "uid": "livith-external-api",
  "panels": [
    {
      "type": "row",
      "title": "외부 API 개요 (RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "API별 RPS",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum by (api) (rate(external_api_request_total[5m]))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API별 에러율 (5xx + network)",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum by (api) (rate(external_api_request_total{status_class=~\"5xx|error\"}[5m])) / clamp_min(sum by (api) (rate(external_api_request_total[5m])), 0.0001)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API별 p95 지연",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "histogram_quantile(0.95, sum by (le, api) (rate(external_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "LastFM 3-Layer 방어막",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "id": 10
    },
    {
      "type": "stat",
      "title": "캐시 Hit Ratio",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum(rate(recommendation_cache_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(recommendation_cache_total[5m])), 0.0001)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "캐시 결과 분포 (hit/stale/miss)",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "id": 12,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum by (result) (rate(recommendation_cache_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limit(error 29) / Retry",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "id": 13,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum(rate(lastfm_rate_limit_total[5m]))",
          "legendFormat": "error 29",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum(rate(lastfm_retry_total[5m]))",
          "legendFormat": "retry",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Coalescing dedup",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "id": 14,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum by (api) (rate(recommendation_coalesced_total[5m]))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Quota / 인증",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "id": 20
    },
    {
      "type": "timeseries",
      "title": "YouTube quota 초과 (1h 증가량)",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "increase(youtube_quota_exceeded_total[1h])",
          "legendFormat": "quota exceeded",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Spotify 에러 (token/404)",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "sum by (kind) (rate(spotify_error_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "트레이스 (Tempo)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "id": 30
    },
    {
      "type": "table",
      "title": "최근 트레이스 (livith-server)",
      "datasource": { "type": "tempo", "uid": "${TEMPO_DS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 31,
      "options": { "frameIndex": 0, "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${TEMPO_DS}" },
          "queryType": "nativeSearch",
          "serviceName": "livith-server",
          "limit": 20,
          "refId": "A"
        }
      ]
    }
  ]
}